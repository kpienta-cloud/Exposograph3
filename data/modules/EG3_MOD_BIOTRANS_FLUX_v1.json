  "input_ports": [
    {
      "name": "substrate_conc_uM",
      "type": "float",
      "description": "Substrate (carcinogen) concentration in micromolar",
      "dtype": "concentration:uM",
      "unit": "uM"
    },
    {
      "name": "enzyme_genotype",
      "type": "string",
      "description": "Metabolizer phenotype: PM | IM | NM | RM | UM",
      "dtype": "multiplier:genotype_activity",
      "unit": "dimensionless"
    },
    {
      "name": "tissue",
      "type": "string",
      "description": "Target tissue from scope.tissues list",
      "dtype": "category:tissue_name"
    },
    {
      "name": "carcinogen_class",
      "type": "string",
      "description": "Carcinogen class key",
      "dtype": "category:carcinogen_class"
    }
  ],
  "output_ports": [
    {
      "name": "activation_score",
      "type": "float",
      "description": "Summed activation flux = Σ(Vmax·[S]/(Km+[S])) for activation enzymes × tissue_weight × genotype_multiplier",
      "dtype": "score:activation",
      "unit": "dimensionless"
    },
    {
      "name": "detoxification_score",
      "type": "float",
      "description": "Summed detoxification flux for detox enzymes",
      "dtype": "score:detoxification",
      "unit": "dimensionless"
    },
    {
      "name": "flux_ratio",
      "type": "float",
      "description": "flux_ratio = activation_score / detoxification_score",
      "dtype": "score:flux_ratio",
      "unit": "dimensionless"
    }
  ],
  "internal_state": [
    {
      "name": "GSH_pool_mM",
      "description": "Hepatic glutathione pool",
      "baseline_mM": 7.5,
      "baseline_range_mM": [
        5.0,
        10.0
      ],
      "critical_threshold_mM": 1.5,
      "synthesis_rate_umol_h_g": 40,
      "half_life_h": 2.5,
      "notes": "Below 20-30% normal GSH, Phase II conjugation capacity drops precipitously. Non-linear tipping point dynamics.",
      "source": "interaction_parameters.json#gsh_depletion; PMC9412641"
    }
  ],
  "causal_role_map": {
    "substrate": "treatment",
    "enzyme_genotype": "moderator",
    "tissue": "context_modifier",
    "flux_ratio": "mediator",
