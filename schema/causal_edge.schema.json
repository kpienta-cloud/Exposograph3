{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "causal_edge.schema.json",
  "title": "ExposoGraph 3.0 Causal Edge",
  "description": "Schema for a promoted causal edge in the Layer-2 causal projection.",
  "type": "object",
  "required": [
    "causal_edge_id",
    "source",
    "target",
    "causal_relation",
    "source_predicate",
    "motif_id",
    "evidence",
    "promotion_status"
  ],
  "properties": {
    "causal_edge_id": {
      "type": "string",
      "pattern": "^EG3\\.CAUSAL\\.EDGE\\.[0-9]+"
    },
    "source": {
      "type": "string",
      "description": "Registry node ID of the source endpoint."
    },
    "target": {
      "type": "string",
      "description": "Registry node ID of the target endpoint."
    },
    "causal_relation": {
      "type": "string",
      "enum": [
        "increases",
        "decreases",
        "activates",
        "detoxifies",
        "damages",
        "mediates",
        "modifies",
        "precedes"
      ],
      "description": "Layer-2 causal vocabulary relation type."
    },
    "source_predicate": {
      "type": "string",
      "description": "Original predicate from the source layer."
    },
    "origin_layer": {
      "type": "string",
      "enum": [
        "registry_baseline",
        "phase3_execution"
      ],
      "description": "Layer from which the edge was promoted."
    },
    "motif_id": {
      "type": "string",
      "description": "Primary bound causal motif ID."
    },
    "motif_ids": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "description": "All bound motif IDs (primary + secondary)."
    },
    "evidence": {
      "type": "object",
      "required": [],
      "properties": {
        "evidence_id": {
          "type": [
            "string",
            "null"
          ]
        },
        "provenance": {
          "type": "array"
        },
        "sources": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "pmid_refs": {
          "type": "array",
          "items": {
            "type": "string"
          }
        },
        "confidence": {
          "type": [
            "string",
            "null"
          ]
        }
      },
      "additionalProperties": true
    },
    "quantitative": {
      "type": "object",
      "properties": {
        "Km_uM": {
          "type": "number"
        },
        "Vmax": {
          "type": "number"
        }
      },
      "additionalProperties": false
    },
    "promotion_status": {
      "type": "string",
      "enum": [
        "causal"
      ]
    },
    "version_origin": {
      "type": "string"
    },
    "module_membership": {
      "type": "array",
      "items": {
        "type": "string"
      }
    }
  },
  "additionalProperties": true
}