{
  "schema_version": "3.0.0",
  "description": "ExposoGraph 3.0 base interface contracts (Layer 0 Phase 2 — 8 typed interfaces with port contracts)",
  "interfaces": [
    {
      "interface_id": "Module",
      "label": "Module",
      "description": "Root interface for all ExposoGraph 3.0 module records. Every module-class-specific interface extends Module.",
      "extends": null,
      "required_fields": [
        "module_id",
        "module_name",
        "module_class",
        "maturity_class",
        "extends",
        "version"
      ],
      "required_input_port_types": [],
      "required_output_port_types": [],
      "maturity_floor": "D"
    },
    {
      "interface_id": "ExposureSourceModule",
      "label": "Exposure Source Module",
      "description": "Interface for modules representing exogenous agents, mixtures, and exposure families. Must characterise the exposure scenario and emit concentration estimates usable by downstream biotransformation modules.",
      "extends": "Module",
      "required_fields": [
        "module_id",
        "module_name",
        "module_class",
        "maturity_class",
        "extends",
        "version",
        "scope",
        "evidence_bundle",
        "mechanism_type"
      ],
      "required_input_port_types": [
        {
          "port_role": "carcinogen_class_input",
          "dtype": "category:carcinogen_class",
          "required": true
        },
        {
          "port_role": "exposure_scenario_input",
          "dtype": "category:exposure_scenario",
          "required": true
        }
      ],
      "required_output_port_types": [
        {
          "port_role": "exposure_multiplier_output",
          "dtype": "multiplier:exposure",
          "unit": "dimensionless",
          "required": true
        },
        {
          "port_role": "concentration_output",
          "dtype": "concentration:uM",
          "unit": "uM",
          "required": true
        }
      ],
      "allowed_mechanism_types": [
        "direct_alkylation",
        "metabolic_activation",
        "oxidative_stress",
        "receptor_activation",
        "mixed"
      ],
      "maturity_floor": "C"
    },
    {
      "interface_id": "BiotransformationModule",
      "label": "Biotransformation Module",
      "description": "Interface for modules representing metabolic activation, detoxification, conjugation, and elimination logic. Must accept substrate concentration and enzyme genotype, and emit a dimensionless activation/detoxification flux ratio.",
      "extends": "Module",
      "required_fields": [
        "module_id",
        "module_name",
        "module_class",
        "maturity_class",
        "extends",
        "version",
        "input_ports",
        "output_ports",
        "parameters"
      ],
      "required_input_port_types": [
        {
          "port_role": "substrate_concentration",
          "dtype": "concentration:uM",
          "unit": "uM",
          "required": true
        },
        {
          "port_role": "enzyme_genotype",
          "dtype": "multiplier:genotype_activity",
          "required": true
        }
      ],
      "required_output_port_types": [
        {
          "port_role": "flux_ratio_output",
          "dtype": "score:flux_ratio",
          "unit": "dimensionless",
          "required": true
        }
      ],
      "allowed_mechanism_types": [
        "activation",
        "detoxification",
        "conjugation",
        "mixed"
      ],
      "maturity_floor": "E"
    },
    {
      "interface_id": "MechanismModule",
      "label": "Mechanism Module",
      "description": "Interface for modules representing pathway perturbation and carcinogenic process logic, including oxidative stress, DNA damage, receptor signalling, and key-characteristic-linked mechanisms. Must reference causal edges and specify mechanism_type.",
      "extends": "Module",
      "required_fields": [
        "module_id",
        "module_name",
        "module_class",
        "maturity_class",
        "extends",
        "version",
        "mechanism_type",
        "causal_edges",
        "input_ports",
        "output_ports"
      ],
      "required_input_port_types": [
        {
          "port_role": "ROS_or_flux_input",
          "dtype": "score:ROS_burden",
          "required": false
        },
        {
          "port_role": "GSH_pool_input",
          "dtype": "fraction:GSH_pool",
          "required": false
        }
      ],
      "required_output_port_types": [
        {
          "port_role": "mechanism_score_output",
          "dtype": "score:ROS_burden",
          "required": false
        }
      ],
      "allowed_mechanism_types": [
        "oxidative_stress",
        "DNA_damage",
        "receptor_signaling",
        "immune_suppression",
        "epigenetic_disruption",
        "competitive_inhibition",
        "mixed"
      ],
      "maturity_floor": "C"
    },
    {
      "interface_id": "TissueContextModule",
      "label": "Tissue Context Module",
      "description": "Interface for modules representing tissue-specific context, expression weighting, cell-type filters, and microenvironmental modifiers. Must emit a normalised tissue expression weight.",
      "extends": "Module",
      "required_fields": [
        "module_id",
        "module_name",
        "module_class",
        "maturity_class",
        "extends",
        "version",
        "scope",
        "input_ports",
        "output_ports"
      ],
      "required_input_port_types": [
        {
          "port_role": "gene_input",
          "dtype": "category:gene_symbol",
          "required": true
        },
        {
          "port_role": "tissue_input",
          "dtype": "category:tissue_name",
          "required": true
        }
      ],
      "required_output_port_types": [
        {
          "port_role": "expression_weight_output",
          "dtype": "weight:tissue_expression",
          "unit": "dimensionless [0-1]",
          "required": true
        }
      ],
      "maturity_floor": "C"
    },
    {
      "interface_id": "SusceptibilityModifierModule",
      "label": "Susceptibility Modifier Module",
      "description": "Interface for modules representing host-side susceptibility modifiers: germline variation, somatic modifiers, age, sex, ancestry-linked frequency context, comorbidity state. Must emit an activity multiplier scaling downstream flux or risk computations.",
      "extends": "Module",
      "required_fields": [
        "module_id",
        "module_name",
        "module_class",
        "maturity_class",
        "extends",
        "version",
        "scope",
        "input_ports",
        "output_ports"
      ],
      "required_input_port_types": [
        {
          "port_role": "gene_input",
          "dtype": "category:gene_symbol",
          "required": true
        },
        {
          "port_role": "genotype_input",
          "dtype": "multiplier:genotype_activity",
          "required": true
        }
      ],
      "required_output_port_types": [
        {
          "port_role": "activity_multiplier_output",
          "dtype": "multiplier:genotype_activity",
          "unit": "dimensionless",
          "required": true
        }
      ],
      "maturity_floor": "C"
    },
    {
      "interface_id": "OutcomeModule",
      "label": "Outcome Module",
      "description": "Interface for modules representing intermediate and endpoint states: adduct burden, pathway activation states, precancer phenotypes, tissue injury states, mutational signatures, and tumour-type-specific outcomes.",
      "extends": "Module",
      "required_fields": [
        "module_id",
        "module_name",
        "module_class",
        "maturity_class",
        "extends",
        "version",
        "output_ports",
        "input_ports",
        "evidence_bundle"
      ],
      "required_input_port_types": [
        {
          "port_role": "flux_ratio_input",
          "dtype": "score:flux_ratio",
          "required": true
        },
        {
          "port_role": "carcinogen_class_input",
          "dtype": "category:carcinogen_class",
          "required": true
        }
      ],
      "required_output_port_types": [
        {
          "port_role": "mutational_signature_output",
          "dtype": "signature:SBS",
          "required": true
        }
      ],
      "maturity_floor": "C"
    },
    {
      "interface_id": "EvidenceAndProvenanceModule",
      "label": "Evidence and Provenance Module",
      "description": "Interface for modules representing the support structure for mechanistic claims: publications, assay context, species, cohort source, evidence direction, contradiction notes, confidence, and version history. Must accept enzyme/substrate identifiers and emit a structured provenance record.",
      "extends": "Module",
      "required_fields": [
        "module_id",
        "module_name",
        "module_class",
        "maturity_class",
        "extends",
        "version",
        "evidence_bundle",
        "input_ports",
        "output_ports"
      ],
      "required_input_port_types": [
        {
          "port_role": "enzyme_input",
          "dtype": "category:gene_symbol",
          "required": true
        },
        {
          "port_role": "substrate_input",
          "dtype": "category:substrate_id",
          "required": true
        }
      ],
      "required_output_port_types": [
        {
          "port_role": "provenance_output",
          "dtype": "record:provenance",
          "required": true
        }
      ],
      "maturity_floor": "C"
    },
    {
      "interface_id": "ExecutableModule",
      "label": "Executable Module",
      "description": "Mix-in interface adding execution requirements to any module. A module that extends ExecutableModule must have typed input and output ports, an equation_type, an update_rule, and at least one parameter. Maturity must be E or T. The Flux module (EG3.MOD.BIOTRANS.FLUX.v1) is the primary concrete exemplar.",
      "extends": "Module",
      "required_fields": [
        "module_id",
        "input_ports",
        "output_ports",
        "equation_type",
        "update_rule",
        "parameters"
      ],
      "required_input_port_types": [
        {
          "port_role": "typed_input",
          "dtype": null,
          "required": true,
          "note": "At least one typed input port (dtype not null) is required"
        }
      ],
      "required_output_port_types": [
        {
          "port_role": "typed_output",
          "dtype": null,
          "required": true,
          "note": "At least one typed output port (dtype not null) is required"
        }
      ],
      "allowed_equation_types": [
        "score-based",
        "rule-based",
        "lookup",
        "Bayesian",
        "SCM",
        "ODE",
        "GLV-coupled",
        "agent-based"
      ],
      "maturity_floor": "E"
    }
  ]
}
